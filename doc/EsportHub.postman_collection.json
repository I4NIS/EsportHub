    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { const d = pm.response.json().data; pm.collectionVariables.set('access_token', d.access_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"email\": \"john@esporthub.test\",\n  \"password\": \"Password1\",\n  \"password_confirmation\": \"Password1\",\n  \"username\": \"johndoe\",\n  \"birthdate\": \"2000-01-15\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { const d = pm.response.json().data; pm.collectionVariables.set('access_token', d.access_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@esporthub.test\",\n  \"password\": \"Password1\"\n}" },
