            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@esporthub.test\",\n  \"password\": \"AdminPassword1\"\n}" },
